// to count the number of digits
import java.util.Scanner;
class Main {
    public static void main(String[] args) {
    Scanner sc= new Scanner(System.in);
    System.out.print("enter a no");
    int n=sc.nextInt();
    
    int result=countDigits(n);
    System.out.print("number of digits:"+result);
    }
    public static int countDigits(int n){
        if (n==0) return 1;
        int cnt=0;
        while (n>0){
            n=n/10;
            cnt++;
        }
        return cnt;
    }
}

// to reverse a number
import java.util.Scanner;
class Main {
    public static void main(String[] args) {
    Scanner sc= new Scanner(System.in);
    System.out.print("enter a no");
    int n=sc.nextInt();
    
    int result=reverseNum(n);
    System.out.print("reversed no is:"+result);
    }
    public static int reverseNum(int n){
        if (n==0) return 0;
        int revNum=0;
        while (n>0){
            int id =n%10; // takes the last digit
            revNum=(revNum*10)+id;
            n=n/10; // removes the last digit
            
        }
        return revNum;
    }
 }   

 // to find if it's palindrome no or not

 import java.util.Scanner;
class Main {
    public static void main(String[] args) {
    Scanner sc= new Scanner(System.in);
    System.out.print("enter a no");
    int n=sc.nextInt();
    
    boolean result=palindromeNum(n);
    System.out.print(result);
    
    }
    public static boolean palindromeNum(int n){
        
        int revNum=0;
        int dup=n;
        while (n>0){
            int id =n%10; // takes the last digit
            revNum=(revNum*10)+id;
            n=n/10; // removes the last digit
            
        }
        if(dup==revNum){
            return true;
        } 
        else{
            return false;
        }
    }
}

// to find armstrong no

import java.util.Scanner;

class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter a number: ");
        int n = sc.nextInt();

        boolean result = isArmstrong(n); 
        System.out.println(result);
    }

    public static boolean isArmstrong(int n){
        int sum = 0;
        int dup = n;

        while(n > 0){
            int id = n % 10;
            sum = sum + (id * id * id);
            n = n / 10;
        }

        return sum == dup;
    }
}

